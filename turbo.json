{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [".env", ".env.*", "tsconfig.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"],
      "outputLogs": "new-only"
    },
    "@hurc/storefront#build": {
      "dependsOn": ["@hurc/graphql#codegen", "@hurc/storefront#codegen", "^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": ["*.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "test/**", "tests/**", "vitest.config.*", "package.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "test/**", "tests/**", "vitest.config.*", "package.json"]
    },
    "@hurc/storefront#test:coverage": {
      "dependsOn": ["@hurc/graphql#codegen", "@hurc/storefront#codegen", "^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/**", "vitest.config.*", "package.json", "sanity.types.ts"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "codegen": {
      "inputs": [
        "src/schema-snapshots/**",
        "src/admin/operations/**",
        "src/shop/operations/**",
        "codegen.ts"
      ],
      "outputs": ["src/admin/generated/**", "src/shop/generated/**"]
    },
    "@hurc/storefront#codegen": {
      "inputs": ["src/sanity/**", "src/lib/sanity/queries.ts", "sanity.config.ts", "sanity.cli.ts"],
      "outputs": ["sanity.types.ts", "schema.json"]
    },
    "@hurc/storefront#typecheck": {
      "dependsOn": ["@hurc/graphql#codegen", "@hurc/storefront#codegen", "^build"],
      "outputs": ["*.tsbuildinfo"]
    },
    "@hurc/storefront#test": {
      "dependsOn": ["@hurc/graphql#codegen", "@hurc/storefront#codegen", "^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/**", "vitest.config.*", "package.json", "sanity.types.ts"]
    },
    "clean": {
      "cache": false
    }
  }
}

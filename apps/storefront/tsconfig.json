{
  "extends": "@hurc/config-tsconfig/base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "playwright.config.ts",
    "next.config.ts",
    "middleware.ts",
    "instrumentation.ts",
    "instrumentation-client.ts",
    "sentry.server.config.ts",
    "sentry.edge.config.ts",
    "sentry.client.config.ts",
    "vitest.config.ts",
    "sanity.config.ts",
    "sanity.cli.ts",
    "sanity.types.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".next", ".turbo"]
}

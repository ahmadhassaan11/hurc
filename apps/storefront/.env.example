# Storefront environment variables — see infra/env.reference.md for context.
# Local dev: copy this file to .env.local and fill in values.
# CI / staging / prod: pulled from Doppler project hurc / configs dev|stg|prd.
# Validation: src/env.ts (server) and src/env.client.ts (NEXT_PUBLIC_*).

# --- Vendure shop-api endpoints ----------------------------------------------
# Public URL the browser hits. Always HTTPS in non-dev.
NEXT_PUBLIC_VENDURE_SHOP_API_URL=http://localhost:3001/shop-api
# Server-side URL the storefront uses for SSR fetches. May be the same as the
# public URL in dev, or a docker-internal URL in production.
VENDURE_SHOP_API_URL_INTERNAL=http://localhost:3001/shop-api

# --- Site / SEO --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analytics ---------------------------------------------------------------
# Plausible loads unconditionally (privacy-first; no consent required).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=hurc.local
# PostHog loads only after explicit analytics consent.
NEXT_PUBLIC_POSTHOG_KEY=phc_dummy_local
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Sanity ------------------------------------------------------------------
# Optional in dev: without these, editorial routes 404 gracefully and the
# home page renders i18n-only. Studio mounts at /studio when configured.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# Server-only token used by the draft client. Read role; never client-exposed.
SANITY_API_READ_TOKEN=
# MUST equal NEXT_REVALIDATE_SECRET on the backend (hurc-sanity-bridge).
# Drives /api/revalidate and /api/draft. See infra/env.reference.md
# §"Important: secret pairs".
SANITY_REVALIDATE_SECRET=

# --- Sentry ------------------------------------------------------------------
# Same DSN is used server-side and client-side. DSN is not a secret per Sentry
# docs; the client SDK still does not load until analytics consent is granted.
NEXT_PUBLIC_SENTRY_DSN=

# --- Logger ------------------------------------------------------------------
# Optional in dev; required in production.
LOGTAIL_SOURCE_TOKEN_STOREFRONT=

# --- Payments (filled in Phase 6) --------------------------------------------
MOLLIE_PROFILE_ID=
STRIPE_PUBLISHABLE_KEY=

# --- Phase 8 Impressum / DSGVO ----------------------------------------------
# Required in production. Dev default placeholders live in
# `src/lib/legal/company.ts` so the legal pages render without crashing
# while these are unset locally.
COMPANY_NAME=
COMPANY_ADDRESS=
COMPANY_VAT=
COMPANY_REGISTRY=
COMPANY_DIRECTORS=
COMPANY_SUPPORT_EMAIL=
COMPANY_SUPPORT_PHONE=

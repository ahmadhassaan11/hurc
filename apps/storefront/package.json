{
  "name": "@hurc/storefront",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:visual": "PW_VISUAL=1 playwright test",
    "test:e2e:visual:update": "PW_VISUAL=1 playwright test --update-snapshots",
    "codegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "clean": "rm -rf dist .next .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "3.2.0",
    "@hookform/resolvers": "5.2.2",
    "@hurc/config-tailwind": "workspace:*",
    "@hurc/graphql": "workspace:*",
    "@hurc/ui": "workspace:*",
    "@portabletext/react": "6.0.3",
    "@sanity/client": "7.22.0",
    "@sanity/image-url": "2.1.1",
    "@sentry/nextjs": "10.51.0",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.37.0",
    "framer-motion": "12.38.0",
    "graphql": "16.13.2",
    "klaro": "0.7.21",
    "next": "15.5.15",
    "next-intl": "4.11.0",
    "next-safe-action": "8.5.2",
    "next-sanity": "11.6.13",
    "pino": "10.3.1",
    "posthog-js": "1.372.6",
    "posthog-node": "5.33.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.75.0",
    "sanity": "5.23.0",
    "server-only": "0.0.1",
    "styled-components": "6.4.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@hurc/config-eslint": "workspace:*",
    "@hurc/config-tsconfig": "workspace:*",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "4.1.5",
    "pino-pretty": "13.1.3",
    "postcss": "^8.5.0",
    "tailwindcss": "4.2.4",
    "typescript": "^5.7.2",
    "vitest": "4.1.5"
  }
}

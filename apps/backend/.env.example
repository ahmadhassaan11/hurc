# HURC backend — local dev env. Copy to .env and fill in. Doppler is the
# source of truth for stg/prd. Keep this file in sync with infra/env.reference.md.

# Runtime
NODE_ENV=development
APP_ENV=dev
PORT=3001
ADMIN_UI_PORT=3002
LOG_LEVEL=debug
RUN_MIGRATIONS_ON_BOOT=false

# Required — boot fails without these
DATABASE_URL=postgres://hurc:hurc@localhost:5432/hurc
REDIS_URL=redis://localhost:6379
COOKIE_SECRET=change_me_to_at_least_32_random_bytes_xxx
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe!Local
STOREFRONT_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001
RESEND_API_KEY=re_localdev_replace_me
EMAIL_FROM=HURC <hello@mail.hurc.local>
SANITY_WEBHOOK_SECRET=replace_me_with_a_min_16_char_secret
NEXT_REVALIDATE_SECRET=replace_me_with_a_min_16_char_secret

# Bunny.net S3-compatible asset storage. Optional in dev (falls back to local
# disk under static/assets); required in stg/prd. All four S3 keys + the URL
# prefix must be set together — partial config fails env validation at boot.
# ASSET_BUNNY_S3_ACCESS_KEY=
# ASSET_BUNNY_S3_SECRET_KEY=
# ASSET_BUNNY_S3_BUCKET=hurc-assets
# ASSET_BUNNY_S3_ENDPOINT=https://storage.bunnycdn.com
# ASSET_PUBLIC_URL_PREFIX=https://assets.hurc.com/

# Meilisearch. Optional in dev (the plugin no-ops cleanly without breaking
# product save events); required in stg/prd. Both keys must be set together.
# MEILI_HOST=http://localhost:7700
# MEILI_MASTER_KEY=replace_me_with_a_min_16_char_key

# Sendcloud. Optional in dev (the calculator falls back to a flat rate);
# required in stg/prd. Both keys must be set together.
# SENDCLOUD_PUBLIC_KEY=
# SENDCLOUD_SECRET_KEY=

# Payments. All optional in dev (no PaymentMethod rows seeded → no checkout
# options); required in stg/prd. Stripe pair must be set together.
# MOLLIE_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional email reply-to (defaults to EMAIL_FROM if unset)
# EMAIL_REPLY_TO=support@mail.hurc.com

# Optional — observability
# LOGTAIL_SOURCE_TOKEN_BACKEND=
# SENTRY_DSN_BACKEND=

# --- Phase 8 Impressum / DSGVO email footer ---------------------------------
# Required in production for the order-confirmation footer block.
# COMPANY_NAME=
# COMPANY_ADDRESS=
# COMPANY_VAT=
# COMPANY_REGISTRY=
# COMPANY_DIRECTORS=
# COMPANY_SUPPORT_EMAIL=
# COMPANY_SUPPORT_PHONE=

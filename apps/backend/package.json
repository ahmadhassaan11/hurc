{
  "name": "@hurc/backend",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dev": "concurrently -n server,worker -c blue,green \"node --watch --enable-source-maps --import @swc-node/register/esm-register --env-file=.env src/index.ts\" \"node --watch --enable-source-maps --import @swc-node/register/esm-register --env-file=.env src/index-worker.ts\"",
    "start": "node dist/index.js",
    "start:worker": "node dist/index-worker.js",
    "seed": "node --enable-source-maps --import @swc-node/register/esm-register --env-file=.env src/seed/seed.ts",
    "migration:generate": "node --enable-source-maps --import @swc-node/register/esm-register --env-file=.env src/migration-cli.ts generate",
    "migration:run": "node --enable-source-maps --import @swc-node/register/esm-register --env-file=.env src/migration-cli.ts run",
    "migration:revert": "node --enable-source-maps --import @swc-node/register/esm-register --env-file=.env src/migration-cli.ts revert",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1041.0",
    "@aws-sdk/lib-storage": "3.1041.0",
    "@nestjs/common": "11.1.19",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@vendure/admin-ui-plugin": "3.6.2",
    "@vendure/asset-server-plugin": "3.6.2",
    "@vendure/common": "3.6.2",
    "@vendure/core": "3.6.2",
    "@vendure/email-plugin": "3.6.2",
    "@vendure/job-queue-plugin": "3.6.2",
    "@vendure/payments-plugin": "3.5.6",
    "@mollie/api-client": "4.5.0",
    "archiver": "7.0.1",
    "bullmq": "5.76.4",
    "express": "4.22.1",
    "graphql": "16.13.2",
    "ioredis": "5.10.1",
    "meilisearch": "0.58.0",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "reflect-metadata": "0.2.2",
    "resend": "6.12.2",
    "rxjs": "7.8.2",
    "stripe": "22.1.0",
    "typeorm": "0.3.28",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@hurc/config-eslint": "workspace:*",
    "@hurc/config-tsconfig": "workspace:*",
    "@types/archiver": "^7.0.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@swc-node/register": "1.11.1",
    "@vitest/coverage-v8": "4.1.5",
    "concurrently": "^9.1.0",
    "pino-pretty": "13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "4.1.5"
  }
}
